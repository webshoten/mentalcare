---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  currentPage?: "profile" | "appointment";
}

const { title, currentPage } = Astro.props;
---

<Layout title={title}>
  <div class="min-h-screen bg-[#FAFAF8]">
    <header
      class="flex items-center justify-between h-[68px] px-10 bg-white border-b border-gray-200"
    >
      <span class="text-xl font-bold text-orange-500">MentalCare</span>

      <nav class="flex items-center gap-8">
        <a
          href="#"
          class={`text-sm font-semibold ${currentPage === "appointment" ? "text-orange-500" : "text-gray-400 hover:text-gray-600"}`}
        >
          予約管理
        </a>
        <a
          href="/counselor/profile"
          class={`text-sm font-semibold ${currentPage === "profile" ? "text-orange-500" : "text-gray-400 hover:text-gray-600"}`}
        >
          プロフィール
        </a>
      </nav>

      <div
        class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 text-sm font-semibold"
      >
        C
      </div>
    </header>

    <slot />
  </div>
</Layout>
