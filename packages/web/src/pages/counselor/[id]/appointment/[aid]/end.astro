---
import AppointmentLayout from "../../../../../layouts/AppointmentLayout.astro";
import { CounselorSessionEnd } from "../../../../../components/counselor/CounselorSessionEnd";

const { id } = Astro.params;
const reason = (Astro.url.searchParams.get("reason") ?? "self") as "self" | "remote";
---

<AppointmentLayout title="セッション終了 | MentalCare">
  <CounselorSessionEnd counselorId={id!} reason={reason} client:only="react" />
</AppointmentLayout>
