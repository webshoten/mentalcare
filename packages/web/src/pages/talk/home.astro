---
import TalkLayout from "../../layouts/TalkLayout.astro";
import { BubbleCanvas } from "@/components/talk/bubble";
---

<TalkLayout title="カウンセラーを探す | MentalCare" currentPage="home">
  <!-- イントロエリア -->
  <div class="flex flex-col items-center gap-3 pt-8 pb-4 px-10 shrink-0">
    <div
      class="flex items-center gap-1.5 bg-green-50 border border-green-200 rounded-full px-4 py-1"
    >
      <span class="w-2 h-2 rounded-full bg-green-500"></span>
      <span class="text-xs font-semibold text-green-700"
        >カウンセラーが対応可能です</span
      >
    </div>
  </div>

  <!-- バブルエリア -->
  <div class="flex-1">
    <BubbleCanvas client:load />
  </div>
</TalkLayout>
