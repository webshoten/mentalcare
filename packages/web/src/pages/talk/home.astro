---
import Layout from "../../layouts/Layout.astro";
import { BubbleCanvas } from "../../components/talk/BubbleCanvas";
---

<Layout title="カウンセラーを探す | MentalCare">
  <div class="flex flex-col h-screen bg-[#FAFAF8]">

    <!-- ヘッダー -->
    <header class="flex items-center justify-between h-[68px] px-10 bg-white border-b border-gray-200 shrink-0">
      <span class="text-xl font-bold text-orange-500">MentalCare</span>
      <nav class="flex items-center gap-8">
        <span class="text-sm font-semibold text-orange-500">カウンセラーを探す</span>
        <a href="#" class="text-sm text-gray-400 hover:text-gray-600">マイ予約</a>
      </nav>
      <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-600 text-sm font-semibold">
        山
      </div>
    </header>

    <!-- イントロエリア -->
    <div class="flex flex-col items-center gap-3 pt-8 pb-4 px-10 shrink-0">
      <h1 class="text-2xl font-bold text-gray-900">今すぐ話せるカウンセラー</h1>
      <p class="text-sm text-gray-500">
        バブルが大きいほど評価が高く、タップするとすぐに相談できます。
      </p>
      <div class="flex items-center gap-1.5 bg-green-50 border border-green-200 rounded-full px-4 py-1">
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
        <span class="text-xs font-semibold text-green-700">カウンセラーが対応可能です</span>
      </div>
    </div>

    <!-- バブルエリア -->
    <div class="flex-1">
      <BubbleCanvas client:load />
    </div>

  </div>
</Layout>
