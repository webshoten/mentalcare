---
import Layout from "../../../../layouts/Layout.astro";
import { CounselorSessionEnd } from "../../../../components/counselor/CounselorSessionEnd";

const { id } = Astro.params;
const reason = (Astro.url.searchParams.get("reason") ?? "self") as "self" | "remote";
const counselorId = Astro.url.searchParams.get("counselorId") ?? "";
---

<Layout title="セッション終了 | MentalCare">
  <CounselorSessionEnd counselorId={counselorId} reason={reason} client:load />
</Layout>
