{
    "version": "0.2.0",
    "configurations": [
        // ─── SST ───────────────────────────────────────────────
        {
            "name": "SST: dev",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/sst",
            "runtimeArgs": [
                "dev"
            ],
            "env": {
                "ENABLE_MCP_DEVTOOLS": "true",
                "NODE_OPTIONS": "--inspect=0"
            },
            "console": "integratedTerminal",
            "autoAttachChildProcesses": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
    ]
}